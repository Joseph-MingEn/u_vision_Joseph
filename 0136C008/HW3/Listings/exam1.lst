                      87     ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                      88     ; 副程式名稱 ︰ READ_LEDCODE
                      89     ; 功  能    ︰ 讀LED 碼儲存在累積器 ACC 中
                      90     ;使用暫存器  ︰ A,DPTR
                      91     ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                      92     
                      93     
                      94     
009D                  95     READ_LEDCODE:
009D 7400             96             MOV     A,#0            ; A 當索引，固定讀 DPTR 指向位址
009F 93               97             MOVC    A,@A+DPTR       ; 從程式記憶體取 1 byte 到 A
00A0 22               98             RET;
                      99     
                     100     
                     101     
                     102     ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                     103     ; 副程式名稱 ︰ DELAY_05S
                     104     ;  功  能    ︰ 延遲時間 0.5 SECOND
                     105     ;使用暫存器  ︰ R7,R6,R5
                     106     ;延遲時間    T=1+R7*[1+R6*(1+R5*2+2)+2]+2
                     107     ;             =1+5*[1+200*(1+1+248*2+2)+2]+2
                     108     ;             =500018 us = 0.5 SEC
                     109     ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                     110     
00A1                 111     DELAY_05S:
00A1 7F05            112             MOV     R7,#05
00A3                 113     a3:        
00A3 7EC8            114             MOV     R6,#200  ; 需要１個機械週期
00A5                 115     a2:
00A5 7DF8            116             MOV     R5,#248
00A7 00              117             NOP              ; 需要１個機械週期
00A8                 118     a1: 
00A8 DDFE            119             DJNZ    R5,a1    ; 需要２個機械週期
00AA DEF9            120             DJNZ    R6,a2
00AC DFF5            121             DJNZ    R7,a3
00AE 22              122             RET
                     123     
