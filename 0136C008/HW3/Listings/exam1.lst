                      lst) OBJECT(.\Objects\exam1.obj) EP

LOC  OBJ            LINE     SOURCE

                       1     ;***********************************************************; 
                       2     ;程式名稱 : ＬＥＤ－Ａ．ＡＳＭ;  
                       3     ;功  能  : 廣告燈;  
                       4     ;說  明  : 使用建表的方式製作廣告燈; 
                       5     ;開關設定 : 無;
                       6     ;***********************************************************
0000                   7             ORG     00H
0000 802E              8             JMP     START          ; 重置後跳到主程式入口
0030                   9             ORG     30H
0030                  10     START:
                      11             ; 三段動畫的畫面數：第一段 5 張、第二段 7 張、第三段 4 張
0030 7806             12             MOV     R0,#6         ; R0 : 第一段迴圈計數
0032 7905             13             MOV     R1,#5         ; R1 : 第二段迴圈計數
0034 7A04             14             MOV     R2,#4         ; R2 : 第三段迴圈計數
0036 7B07             15             MOV     R3,#7
0038 9000D9           16             MOV     DPTR,#LED_TABLE ; DPTR 指向 LED 顯示資料表
003B                  17     d1:
                      18             ; 每次 d1 讀出 4 bytes，依序送到 P0~P3，形成 1 個畫面
003B 119D             19             CALL    READ_LEDCODE    ; 讀LED 碼
003D F580             20             MOV     P0,A            ; 將LED 碼 送到PORT-0
003F A3               21             INC     DPTR            ; 指向下一筆 LED 顯示資料
0040 119D             22             CALL    READ_LEDCODE    ; 讀LED 碼
0042 F590             23             MOV     P1,A            ; 將LED 碼 送到PORT-1
0044 A3               24             INC     DPTR            ; 指向下一筆 LED 顯示資料
0045 119D             25             CALL    READ_LEDCODE    ; 讀LED 碼
0047 F5A0             26             MOV     P2,A            ; 將LED 碼 送到PORT-2
0049 A3               27             INC     DPTR            ; 指向下一筆 LED 顯示資料
004A 119D             28             CALL    READ_LEDCODE    ; 讀LED 碼
004C F5B0             29             MOV     P3,A            ; 將LED 碼 送到PORT-3
004E A3               30             INC     DPTR            ; 指向下一筆 LED 顯示資料
004F 11CB             31             CALL    DELAY_1S      ; 延遲時間 0.5 SECOND
0051 D8E8             32             DJNZ    R0,d1          ; 第一段尚未播完就繼續
0053                  33     d2:
                      34             ; 第二段動畫：資料緊接在第一段後面，DPTR 不重設
0053 119D             35             CALL    READ_LEDCODE    ; 讀LED 碼
0055 F580             36             MOV     P0,A            ; 將LED 碼 送到PORT-0
0057 A3               37             INC     DPTR            ; 指向下一筆 LED 顯示資料
0058 119D             38             CALL    READ_LEDCODE    ; 讀LED 碼
005A F590             39             MOV     P1,A            ; 將LED 碼 送到PORT-1
005C A3               40             INC     DPTR            ; 指向下一筆 LED 顯示資料
005D 119D             41             CALL    READ_LEDCODE    ; 讀LED 碼
005F F5A0             42             MOV     P2,A            ; 將LED 碼 送到PORT-2
0061 A3               43             INC     DPTR            ; 指向下一筆 LED 顯示資料
0062 119D             44             CALL    READ_LEDCODE    ; 讀LED 碼
0064 F5B0             45             MOV     P3,A            ; 將LED 碼 送到PORT-3
0066 A3               46             INC     DPTR            ; 指向下一筆 LED 顯示資料
0067 11A1             47             CALL    DELAY_05S      ; 延遲時間 0.5 SECOND
0069 D9E8             48             DJNZ    R1,d2          ; 第二段尚未播完就繼續
006B                  49     d3:
                      50             ; 第三段動畫：繼續順序讀表，播完後回 START 重播全部
006B 119D             51             CALL    READ_LEDCODE    ; 讀LED 碼
006D F580             52             MOV     P0,A            ; 將LED 碼 送到PORT-0
006F A3               53             INC     DPTR            ; 指向下一筆 LED 顯示資料
0070 119D             54             CALL    READ_LEDCODE    ; 讀LED 碼
0072 F590             55             MOV     P1,A            ; 將LED 碼 送到PORT-1
0074 A3               56             INC     DPTR            ; 指向下一筆 LED 顯示資料
0075 119D             57             CALL    READ_LEDCODE    ; 讀LED 碼
