                      25     
002D                  26     SUB_INT0:
002D 08               27             INC R0
002E B80A02           28             CJNE R0,#0AH,INT0_OK
0031 7800             29             MOV R0,#00H        ; 超過9回到0
0033                  30     INT0_OK:
0033 113F             31             CALL DISPLAY
0035 32               32             RETI
                      33     
0036                  34     SUB_INT1:
0036 18               35             DEC R0
0037 B8FF02           36             CJNE R0,#0FFH,INT1_OK
003A 7809             37             MOV R0,#09H        ; 0再減回到9
                      38     
003C                  39     INT1_OK:
003C 113F             40             CALL DISPLAY
003E 32               41             RETI
                      42     
                      43     
003F                  44     DISPLAY:
003F E8               45             MOV A,R0
0040 93               46             MOVC A,@A+DPTR
0041 F580             47             MOV P0,A
0043 22               48             RET
                      49     
0044                  50     TABLE:
