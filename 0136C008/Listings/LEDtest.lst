A51 MACRO ASSEMBLER  LEDTEST                                                              03/24/2026 00:16:25 PAGE     1


MACRO ASSEMBLER A51 V8.2.7.0
OBJECT MODULE PLACED IN .\Objects\LEDtest.obj
ASSEMBLER INVOKED BY: C:\Keil_v5\C51\BIN\A51.EXE LEDtest.A51 SET(SMALL) DEBUG PRINT(.\Listings\LEDtest.lst) OBJECT(.\Obj
                      ects\LEDtest.obj) EP

LOC  OBJ            LINE     SOURCE

0000 74FE              1                     MOV A,#0FEH
0002 F590              2     START:  MOV P1,A
0004 23                3                     RL A                    
0005 1109              4                     ACALL DELAY
0007 0102              5                     AJMP START
0009 78F8              6     DELAY:  MOV R0,#248
000B 79C8              7     D1:     MOV R1,#200
000D D9FE              8     D2:     DJNZ R1,D2
000F D8FA              9                     DJNZ R0,D1
0011 22               10                     RET
                      11                     END;***********************************************************; 
                             ;程式名稱 : ＬＥＤ－Ａ．ＡＳＭ;  
                             ;功  能  : 廣告燈;  
                             ;說  明  : 使用建表的方式製作廣告燈; 
                             ;開關設定 : 無;
                             ;***********************************************************
                                     ORG     00H
*** WARNING #A73 IN 17 (LEDtest.A51, LINE 17): TEXT FOUND BEYOND END STATEMENT - IGNORED
                                     JMP     START
                                     ORG     30H
                             START:
                                     MOV     R0,#30          ; R0 : 迴圈計數
                                     MOV     DPTR,#LED_TABLE ; DPTR 指向 LED 顯示資料表
                             d1:
                                     CALL    READ_LEDCODE    ; 讀LED 碼
                                     MOV     P0,A            ; 將LED 碼 送到PORT-0
                                     INC     DPTR            ; 指向下一筆 LED 顯示資料
                                     CALL    READ_LEDCODE    ; 讀LED 碼
                                     MOV     P1,A            ; 將LED 碼 送到PORT-1
                                     INC     DPTR            ; 指向下一筆 LED 顯示資料
                                     CALL    READ_LEDCODE    ; 讀LED 碼
                                     MOV     P2,A            ; 將LED 碼 送到PORT-2
                                     INC     DPTR            ; 指向下一筆 LED 顯示資料
                                     CALL    READ_LEDCODE    ; 讀LED 碼
                                     MOV     P3,A            ; 將LED 碼 送到PORT-3
                                     INC     DPTR            ; 指向下一筆 LED 顯示資料
                                     CALL    DELAY_05S      ; 延遲時間 0.5 SECOND
                                     DJNZ    R0,d1
                                     JMP     START;
                             
                             
                             
                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             ; 副程式名稱 ︰ READ_LEDCODE
                             ; 功  能    ︰ 讀LED 碼儲存在累積器 ACC 中
                             ;使用暫存器  ︰ A,DPTR
                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             
                             
                             
                             READ_LEDCODE:
                                     MOV     A,#0            ;
                                     MOVC    A,@A+DPTR       ; 將查表所得之資料送至 P0
                                     RET;
                             
                             
                             
A51 MACRO ASSEMBLER  LEDTEST                                                              03/24/2026 00:16:25 PAGE     2

                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             ; 副程式名稱 ︰ DELAY_0.2S
                             ;  功  能    ︰ 延遲時間 0.5 SECOND
                             ;使用暫存器  ︰ R7,R6,R5
                             ;延遲時間    T=1+R7*[1+R6*(1+R5*2+2)+2]+2
                             ;             =1+5*[1+200*(1+1+248*2+2)+2]+2
                             ;             =500018 us = 0.5 SEC
                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             
                             DELAY_05S:
                                     MOV     R7,#05
                             a3:        
                                     MOV     R6,#200  ; 需要１個機械週期
                             a2:
                                     MOV     R5,#248
                                     NOP              ; 需要１個機械週期
                             a1: 
                                     DJNZ    R5,a1    ; 需要２個機械週期
                                     DJNZ    R6,a2
                                     DJNZ    R7,a3
                                     RET
                             
                             
                             
                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             ; LED_TABLE  的資料 1 表示LED 會亮
                             ;@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
                             
                             
                             LED_TABLE:                ; LED 顯示資料表
                             
                                             ; ===== P0 =====
                                             DB 01H,00H,00H,00H
                                             DB 02H,00H,00H,00H
                                             DB 04H,00H,00H,00H
                                             DB 08H,00H,00H,00H
                                             DB 10H,00H,00H,00H
                                             DB 20H,00H,00H,00H
                                             DB 40H,00H,00H,00H
                                             DB 80H,00H,00H,00H
                             
                                             ; ===== P1 =====
                                             DB 00H,01H,00H,00H
                                             DB 00H,02H,00H,00H
                                             DB 00H,04H,00H,00H
                                             DB 00H,08H,00H,00H
                                             DB 00H,10H,00H,00H
                                             DB 00H,20H,00H,00H
                                             DB 00H,40H,00H,00H
                                             DB 00H,80H,00H,00H
                             
                                             ; ===== P2 =====
                                             DB 00H,00H,01H,00H
                                             DB 00H,00H,02H,00H
                                             DB 00H,00H,04H,00H
                                             DB 00H,00H,08H,00H
                                             DB 00H,00H,10H,00H
                                             DB 00H,00H,20H,00H
                                             DB 00H,00H,40H,00H
                                             DB 00H,00H,80H,00H
                             
                                             ; ===== P3 =====
                                             DB 00H,00H,00H,01H
                                             DB 00H,00H,00H,02H
                                             DB 00H,00H,00H,04H
                                             DB 00H,00H,00H,08H
